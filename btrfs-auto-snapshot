  # ID 5017 gen 40083 top level 256 path <FS_TREE>/home/foobar
  # ID 256 gen 40129 top level 5 path home
  # root@c-h730:/home#
  #
  # https://lore.kernel.org/linux-btrfs/c015f1943def5e892b0aac540d1ce5a3d143ed6b.1718995160.git.osandov@fb.com/

  # root@c-h730:/home# ls -lisa /sys/fs/btrfs
  # total 0
  # 38868 0 drwxr-xr-x  4 root root 0 Mar  7 11:22 .
  #     2 0 drwxr-xr-x 11 root root 0 Mar  4 15:33 ..
