#!/usr/bin/env bash

##
# Automatically create, rotate and destroy BTRFS snapshots.
#

set -o errexit
set -o errtrace
set -o functrace
set -o nounset
set -o pipefail
#set -o xtrace

# shellcheck source=SCRIPTDIR/inc/args.bash
source "$(dirname "${0}" | xargs -d'\n' readlink -f -n | xargs -d'\n' printf '%s/inc/args.bash' || true)"

# shellcheck source=SCRIPTDIR/inc/snaps.bash
source "$(dirname "${0}" | xargs -d'\n' readlink -f -n | xargs -d'\n' printf '%s/inc/snaps.bash' || true)"

main() {
  args::parse "${@}"
  args::print_usage_and_exit_if

  snaps::do "${ARGS['snaps.paths']}"
  snaps::rm "${ARGS['snaps.paths']}"

  # TODO Add support for // by checking if that is the path to support, calculate all paths and process like explicitly
  #   given. Don't validate given paths too much to not need to care too much about different BTRFS layouts. Try to use
  #   mounted dirs as much as possible?
}

main "${@}"
